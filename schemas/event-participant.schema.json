{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://paper-data-suite.github.io/pds-portia/schemas/event-participant.schema.json",
  "title": "Portia Event Participant",
  "description": "Canonical Portia Event Participant record stored at classes/<class_id>/modules/portia/work/<work_id>/records/event_participant/<participant_id>.json.",
  "$comment": "Application validation remains responsible for path/identity agreement, parent Event and Core reference existence, Actor existence, duplicate active durable subjects, participant lifecycle transitions, Event activation requirements, timestamp ordering, creation-provenance immutability, paper/import review, supersession consistency, and child-reference migration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "record_type",
    "module_id",
    "class_id",
    "work_id",
    "participant_id",
    "status",
    "subject",
    "creation_source",
    "created_at",
    "created_by",
    "updated_at",
    "updated_by"
  ],
  "properties": {
    "schema_version": {
      "const": "1"
    },
    "record_type": {
      "const": "event_participant"
    },
    "module_id": {
      "const": "portia"
    },
    "class_id": {
      "$ref": "#/$defs/safeId"
    },
    "work_id": {
      "$ref": "#/$defs/eventId"
    },
    "participant_id": {
      "$ref": "#/$defs/eventParticipantId"
    },
    "status": {
      "enum": [
        "proposed",
        "active",
        "invalidated",
        "superseded"
      ]
    },
    "subject": {
      "$ref": "#/$defs/subject"
    },
    "supersedes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "$ref": "#/$defs/participantSupersessionRef"
      },
      "description": "Canonical forward links from this corrected or resolved participant to prior participant records within the same Event."
    },
    "creation_source": {
      "$ref": "#/$defs/creationSource"
    },
    "created_at": {
      "$ref": "#/$defs/timestamp"
    },
    "created_by": {
      "$ref": "#/$defs/attributionAgent"
    },
    "updated_at": {
      "$ref": "#/$defs/timestamp"
    },
    "updated_by": {
      "$ref": "#/$defs/attributionAgent"
    }
  },
  "$defs": {
    "nonEmptyText": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "safeId": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*$",
      "description": "Conservative structural safety pattern; Core remains authoritative for identifier validation."
    },
    "eventId": {
      "type": "string",
      "pattern": "^evt_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "eventParticipantId": {
      "type": "string",
      "pattern": "^ep_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "actorId": {
      "type": "string",
      "pattern": "^actr_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "routeId": {
      "type": "string",
      "pattern": "^rt_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "pageRecordId": {
      "type": "string",
      "pattern": "^pg_[A-Za-z0-9][A-Za-z0-9._-]*$"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "RFC 3339 timestamp with an explicit UTC offset or Z.",
      "pattern": "(?:Z|[+-][0-9]{2}:[0-9]{2})$"
    },
    "subject": {
      "oneOf": [
        {
          "$ref": "#/$defs/rosterStudentSubject"
        },
        {
          "$ref": "#/$defs/actorSubject"
        },
        {
          "$ref": "#/$defs/descriptivePersonSubject"
        },
        {
          "$ref": "#/$defs/unknownPersonSubject"
        }
      ]
    },
    "rosterStudentSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "student_ref",
        "display_snapshot"
      ],
      "properties": {
        "kind": {
          "const": "roster_student"
        },
        "student_ref": {
          "$ref": "#/$defs/studentRef"
        },
        "display_snapshot": {
          "$ref": "#/$defs/displaySnapshot"
        }
      }
    },
    "studentRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "class_id",
        "student_id"
      ],
      "properties": {
        "class_id": {
          "$ref": "#/$defs/safeId"
        },
        "student_id": {
          "$ref": "#/$defs/safeId"
        }
      },
      "description": "Complete Core roster-qualified student reference. The roster class may differ from the Event owning class."
    },
    "displaySnapshot": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "display_name"
      ],
      "properties": {
        "display_name": {
          "$ref": "#/$defs/nonEmptyText"
        }
      },
      "description": "Nonauthoritative historical display snapshot; never a durable identity key."
    },
    "actorSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "actor_id",
        "display_snapshot"
      ],
      "properties": {
        "kind": {
          "const": "actor"
        },
        "actor_id": {
          "$ref": "#/$defs/actorId"
        },
        "display_snapshot": {
          "$ref": "#/$defs/displaySnapshot"
        }
      }
    },
    "descriptivePersonSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "description_type",
        "display_label"
      ],
      "properties": {
        "kind": {
          "const": "descriptive_person"
        },
        "description_type": {
          "enum": [
            "outside_student",
            "family_member",
            "school_staff",
            "visitor",
            "community_member",
            "other"
          ]
        },
        "display_label": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "detail": {
          "$ref": "#/$defs/nonEmptyText"
        }
      },
      "$comment": "Application validation should require sufficient clarification when description_type is other; the required display_label may itself provide that clarification."
    },
    "unknownPersonSubject": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "kind",
        "reason"
      ],
      "properties": {
        "kind": {
          "const": "unknown_person"
        },
        "reason": {
          "enum": [
            "identity_not_known",
            "identity_not_reported",
            "identity_withheld",
            "ambiguous_source",
            "ambiguous_paper_mark",
            "legacy_import"
          ]
        },
        "description": {
          "$ref": "#/$defs/nonEmptyText"
        }
      }
    },
    "participantSupersessionRef": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "participant_id",
        "reason"
      ],
      "properties": {
        "participant_id": {
          "$ref": "#/$defs/eventParticipantId"
        },
        "reason": {
          "enum": [
            "identity_resolved",
            "identity_corrected",
            "duplicate_consolidated",
            "subject_variant_changed",
            "participant_relationship_corrected",
            "other"
          ]
        },
        "detail": {
          "$ref": "#/$defs/nonEmptyText"
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "reason": {
                "const": "other"
              }
            },
            "required": [
              "reason"
            ]
          },
          "then": {
            "required": [
              "detail"
            ]
          }
        }
      ],
      "description": "Forward replacement relationship to a prior participant in the same Event. Application validation confirms reference existence and same-Event scope."
    },
    "creationSource": {
      "oneOf": [
        {
          "$ref": "#/$defs/digitalEntrySource"
        },
        {
          "$ref": "#/$defs/paperCaptureSource"
        },
        {
          "$ref": "#/$defs/importSource"
        }
      ]
    },
    "digitalEntrySource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type"
      ],
      "properties": {
        "type": {
          "const": "digital_entry"
        }
      }
    },
    "paperCaptureSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "stage",
        "route_id",
        "page_record_id"
      ],
      "properties": {
        "type": {
          "const": "paper_capture"
        },
        "stage": {
          "enum": [
            "preallocated",
            "ingested"
          ]
        },
        "route_id": {
          "$ref": "#/$defs/routeId"
        },
        "page_record_id": {
          "$ref": "#/$defs/pageRecordId"
        }
      },
      "$comment": "Event Participants created from returned-page interpretation ordinarily use stage ingested; application workflow validation may restrict preallocated use."
    },
    "importSource": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "source_label"
      ],
      "properties": {
        "type": {
          "const": "import"
        },
        "source_label": {
          "$ref": "#/$defs/nonEmptyText"
        },
        "external_reference": {
          "$ref": "#/$defs/nonEmptyText"
        }
      }
    },
    "attributionAgent": {
      "oneOf": [
        {
          "$ref": "#/$defs/localOperator"
        },
        {
          "$ref": "#/$defs/systemProcess"
        }
      ]
    },
    "localOperator": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "display_label"
      ],
      "properties": {
        "type": {
          "const": "local_operator"
        },
        "display_label": {
          "$ref": "#/$defs/nonEmptyText"
        }
      }
    },
    "systemProcess": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "process_id"
      ],
      "properties": {
        "type": {
          "const": "system_process"
        },
        "process_id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    }
  }
}
